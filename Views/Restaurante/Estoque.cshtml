@model EstoqueViewModel
@{
    ViewData["Title"] = "Estoque";
}

    <div>
        <p class="eyebrow">Estoque</p>
        <h2>Ingredientes em controle</h2>
    </div>
</section>

<section class="panel-grid split">
    <article class="panel-card">
        <h3>Novo ingrediente</h3>
        <form asp-action="AdicionarIngrediente" method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <label>
                <span>Nome</span>
                <input asp-for="Nome" />
            </label>
            <label>
                <span>Quantidade</span>
                <input asp-for="Quantidade" type="number" step="0.01" min="0" />
            </label>
            <label>
                <span>Unidade</span>
                <input asp-for="UnidadeMedida" />
            </label>
            <label>
                <span>Quantidade mínima</span>
                <input asp-for="QuantidadeMinima" type="number" step="0.01" min="0" />
            </label>
            <button type="submit" class="primary-button">Salvar ingrediente</button>
        </form>
    </article>

    <article class="panel-card">
        <h3>Lista de ingredientes</h3>
        @if (Model.Ingredientes.Count == 0)
        {
            <p class="muted">Nenhum ingrediente cadastrado.</p>
        }
        else
        {
            <div class="list-cards">
                @foreach (var ingrediente in Model.Ingredientes)
                {
                    var statusClass = ingrediente.VerificarDisponibilidade() ? "status-ok" : "status-low";
                    var statusTexto = ingrediente.VerificarDisponibilidade() ? "OK" : "Baixo";
                    <div class="item-card">
                        <div>
                            <strong>@ingrediente.Nome</strong>
                            <p>@ingrediente.Quantidade.ToString("F2") @ingrediente.UnidadeMedida · mínimo @ingrediente.QuantidadeMinima.ToString("F2")</p>
                        </div>
                        <span class="@statusClass">@statusTexto</span>
                    </div>
                }
            </div>
        }
    </article>
</section>
