@model CardapioViewModel
@{
    ViewData["Title"] = "Cardápio";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Cardápio</p>
        <h2>Pratos cadastrados</h2>
    </div>
</section>

<section class="panel-grid split">
    <article class="panel-card">
        <h3>Novo prato</h3>
        <form asp-action="AdicionarPrato" method="post" class="stack-form">
            @Html.AntiForgeryToken()
            <label>
                <span>Nome</span>
                <input asp-for="Nome" />
            </label>
            <label>
                <span>Descrição</span>
                <textarea asp-for="Descricao" rows="4"></textarea>
            </label>
            <label>
                <span>Preço</span>
                <input asp-for="Preco" type="number" step="0.01" min="0" />
            </label>
            <button type="submit" class="primary-button">Salvar prato</button>
        </form>
    </article>

    <article class="panel-card">
        <h3>Lista de pratos</h3>
        @if (Model.Pratos.Count == 0)
        {
            <p class="muted">Nenhum prato cadastrado.</p>
        }
        else
        {
            <div class="list-cards">
                @foreach (var prato in Model.Pratos)
                {
                    <div class="item-card">
                        <div>
                            <strong>@prato.Nome</strong>
                            @if (!string.IsNullOrWhiteSpace(prato.Descricao))
                            {
                                <p>@prato.Descricao</p>
                            }
                        </div>
                        <span>R$ @prato.Preco.ToString("F2")</span>
                    </div>
                }
            </div>
        }
    </article>
</section>
